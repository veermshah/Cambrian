# =============================================================================
# Cambrian — environment variables
# Copy this file to .env and fill in real values. .env is gitignored.
# =============================================================================

# Required: which network the swarm operates on. devnet for the first 30 days.
NETWORK=devnet

# Required: Supabase Postgres — connection used by `golang-migrate`.
# golang-migrate needs advisory locks + prepared statements, which pgBouncer
# in transaction-pooling mode does not support. Two valid options:
#   • Direct connection: `db.<ref>.supabase.co:5432` (free tier is IPv6-only;
#     unreachable from many networks without an IPv4 add-on).
#   • Session-mode pooler: `<region>.pooler.supabase.com:5432` — same host as
#     the transaction pooler, port 5432. Recommended on the free tier.
# From Supabase: Project Settings → Database → Connection string → "Session".
DATABASE_URL=

# Optional: Supabase Postgres — transaction-mode pgBouncer (port 6543).
# Used by the app's pgx.Pool with QueryExecModeExec (no server-side prepares).
# Falls back to DATABASE_URL when unset.
# From Supabase: Project Settings → Database → Connection string → "Transaction".
DATABASE_POOL_URL=

# Required: Upstash Redis — TLS endpoint.
# Format: rediss://default:<password>@<host>:6379
# From Upstash database page → Connect → "Redis" tab.
REDIS_URL=

# Required: 32-byte master key as 64 hex chars. Generate with:
#   openssl rand -hex 32
# Wallet keys are encrypted at rest with AES-256-GCM under this key.
MASTER_ENCRYPTION_KEY=

# Required: API key gating the dashboard read API via X-Api-Key header.
# Generate with: openssl rand -hex 24
API_KEY=

# Optional: LLM provider keys. Required by chunk 6+ (strategist, quality check,
# adversarial review). Leave empty to skip LLM-dependent code paths.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Optional: chain RPC URLs. Required by chunk 4 (Solana) and chunk 5 (Base).
HELIUS_DEVNET_URL=
ALCHEMY_BASE_SEPOLIA_URL=

# Optional: Telegram notifications. Required by chunk 28 to deliver alerts.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional: monthly cap on LLM + infra + RPC spend. Defaults to 100.
MONTHLY_BUDGET_USD=100

# Optional: log level — debug | info | warn | error. Defaults to info.
LOG_LEVEL=info
